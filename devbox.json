{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.13.0/.schema/devbox.schema.json",
  "packages": [
    "github:mridang/nixpkgs?dir=pkgs/swift#swift",
    "docker@latest",
    "swiftlint@latest"
  ],
  "shell": {
    "init_hook": [
      "unset NIX_CC NIX_CC_WRAPPER_TARGET_HOST_aarch64_apple_darwin NIX_BINTOOLS NIX_BINTOOLS_WRAPPER_TARGET_HOST_aarch64_apple_darwin NIX_CFLAGS_COMPILE NIX_LDFLAGS NIX_HARDENING_ENABLE NIX_ENFORCE_NO_NATIVE NIX_DONT_SET_RPATH NIX_IGNORE_LD_THROUGH_GCC"
    ],
    "scripts": {
      "build":            "swift build",
      "test":             "swift test",
      "test:unit":        "swift test --filter TestcontainersCoreTests",
      "test:integration": "swift test --filter TestcontainersComposeTests",
      "lint":             "swiftlint lint --strict Sources Tests",
      "lint:fix":         "swiftlint --fix Sources Tests",
      "format":           "swift format --recursive --in-place Sources Tests",
      "format:check":     "swift format --recursive --dry-run Sources Tests",
      "doc":              "swift package generate-documentation"
    }
  }
}
